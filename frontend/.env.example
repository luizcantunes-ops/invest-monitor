PORT=3001
HOST=127.0.0.1
NODE_ENV=development
ALLOWED_ORIGINS=http://127.0.0.1:3001

# Senha de acesso ao dashboard.
# Em produção (NODE_ENV=production), APP_PASSWORD é obrigatório.
APP_PASSWORD=

# Token compartilhado com o backend Python.
# Deve ser igual ao INTERNAL_API_TOKEN do src/.env
INTERNAL_API_TOKEN=change-me-to-a-long-random-string

# URL do backend Python
PYTHON_API_URL=http://127.0.0.1:8000

ALPHA_VANTAGE_API_KEY=
